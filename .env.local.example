# NextAuth 配置（必需）
NEXTAUTH_SECRET=your-secret-key-change-in-production
NEXTAUTH_URL=http://localhost:3000

# 管理员账号配置（格式：用户名:密码，多个用户用逗号分隔）
ADMIN_USERS=admin:admin123

# 公司邮箱注册限制（多个域名用英文逗号分隔）
COMPANY_EMAIL_DOMAINS=tuyoogame.com
NEXT_PUBLIC_COMPANY_EMAIL_DOMAINS=tuyoogame.com
COMPANY_TEAM_NAME=爆款工坊团队
COMPANY_TEAM_SLUG=baokuan-workshop

# 太石 / Tuyoo LLM 网关
TAISHI_API_KEY=
TAISHI_BASE_URL=https://relay.tuyoo.com/v1
TAISHI_TEXT_MODEL=glm-4.6
TAISHI_CREATIVE_MODEL=gemini-3-flash-preview
TAISHI_QC_MODEL=gemini-3-flash-preview

# 兼容旧代码命名
LLM_TOKEN=
TUYOO_LLM_BASE_URL=https://relay.tuyoo.com/v1
TUYOO_LLM_DEFAULT_MODEL=glm-4.6
TUYOO_LLM_VIDEO_MODEL=gemini-3-flash-preview

# 爆款工坊入口（底部导航「爆款工坊」点击跳转的地址）
# 不配置时默认 http://localhost:3000（本地 super-insight 开发地址）
# 部署到线上时：填 super-insight 的线上地址，例如 https://xxx.railway.app
# NEXT_PUBLIC_BAOKUAN_URL=https://你的爆款工坊线上地址
